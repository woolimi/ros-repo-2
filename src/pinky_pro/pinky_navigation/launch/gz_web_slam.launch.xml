<?xml version='1.0'?>
<launch>
    <arg name="ip" default="127.0.0.1"/>
    <arg name="port" default="8080"/>
    <arg name="use_sim_time" default="True"/>
    <arg name="params_file" default="$(find-pkg-share pinky_navigation)/params/nav2_params.yaml"/>
    <arg name="slam_params_file" default="$(find-pkg-share pinky_navigation)/params/mapper_params.yaml"/>

    <node pkg="pinky_navigation" exec="nav2_web_server.py" name="nav2_web_server" output="screen">
        <param name="ip" value="$(var ip)"/>
        <param name="port" value="$(var port)"/>
    </node>

    <include file="$(find-pkg-share pinky_navigation)/launch/gz_bringup_launch.xml">
        <arg name="params_file" value="$(var params_file)"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="map" value=""/>
    </include>

    <include file="$(find-pkg-share pinky_navigation)/launch/map_building.launch.xml">
        <arg name="slam_params_file" value="$(var slam_params_file)"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>
    
</launch>