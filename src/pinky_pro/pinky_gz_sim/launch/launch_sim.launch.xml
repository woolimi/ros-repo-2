<?xml version='1.0' ?>

<launch>
    <arg name="namespace" default=""/>
    <arg name="robot_name" default="$(var namespace)pinky"/>
    <arg name="cam_tilt_deg" default="0"/>
    <arg name="world_name" default="pinky_factory.world"/>
    <arg name="world" default="$(find-pkg-share pinky_gz_sim)/worlds/$(var world_name)"/>
    <arg name="bridge_params" default="$(find-pkg-share pinky_gz_sim)/params/pinky_bridge.yaml"/>
    
    <set_env name="GZ_SIM_RESOURCE_PATH" value="$(find-pkg-share pinky_description)/../:/$(find-pkg-share pinky_gz_sim)/models:/$(env HOME)/.gazebo/models"/>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name='gz_args' value='-r -s -v4, $(var world)'/>
        <arg name='on_exit_shutdown' value='true'/>
    </include>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name='gz_args' value='-g -v4 '/>
    </include>

    <include file="$(find-pkg-share pinky_description)/launch/upload_robot.launch.py">
        <arg name='namespace' value='$(var namespace)'/>
        <arg name='use_sim_time' value='True'/>
        <arg name='is_sim' value='True'/>
        <arg name='cam_tilt_deg' value='$(var cam_tilt_deg)'/>
    </include>

    <node pkg="ros_gz_sim" exec="create" name='create' output='screen' args="-name $(var robot_name) -topic $(var namespace)/robot_description -x 0.0 -y 0.0 -z 0.1">
        <param name='use_sim_time' value='True'/>
    </node>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" name='parameter_bridge' output='screen' args="--ros-args -p config_file:=$(var bridge_params)"/>
    <node pkg="ros_gz_image" exec="image_bridge" name='image_bridge' output='screen' args="/camera/image_raw"/>
    <node pkg="ros_gz_image" exec="image_bridge" name='image_bridge' output='screen' args="/camera"/>
</launch>